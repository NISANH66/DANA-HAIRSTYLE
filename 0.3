<!-- PORTFOLIO CAROUSEL -->
<section class="portfolio" id="gallery">
  <div class="section-header fade">
    <div class="s-eye">פורטפוליו</div>
    <h2 class="s-title" style="color:#fff;">עבודות אמיתיות, <em>תוצאות אמיתיות</em></h2>
    <p class="s-sub">כל תסרוקת מגולפת בדיוק, תשוקה ושנות מומחיות. החליקי כדי לראות עוד.</p>
  </div>
  <div class="carousel-wrap fade d1">
    <button class="car-nav prev" onclick="scrollCarousel(-1)" aria-label="הקודם">‹</button>
    <div class="carousel" id="portfolioCarousel">
      <div class="car-item">
        <img src="data:image/jpeg;base64," alt="צמידי שיער טבעי" loading="lazy">
        <div class="car-label">תוספות שיער · צמיד שיער טבעי</div>
      </div>
      <div class="car-item">
        <video autoplay muted loop playsinline webkit-playsinline="true" preload="auto" disablepictureinpicture>
          <source src="media/protein-1.mp4" type="video/mp4">
        </video>
        <div class="car-label">שיקום בחלבון</div>
