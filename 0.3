<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>דנה בז׳רנו | Hair Style</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Heebo:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --cream:#FAFAF8;--warm:#F5F0EA;--nude:#E8D5C4;
    --rose:#C4977A;--deep:#1C1410;--gold:#B8935A;--mid:#6B4F3A;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{font-family:"Heebo",sans-serif;background:var(--cream);color:var(--deep);overflow-x:hidden;direction:rtl;}


  /* NAV */
  nav{
    position:fixed;top:0;right:0;left:0;z-index:200;
    display:flex;align-items:center;justify-content:space-between;
    padding:1rem 3rem;
    background:rgba(250,250,248,0.93);
    backdrop-filter:blur(16px);
    border-bottom:1px solid rgba(196,151,122,0.18);
    transition:box-shadow .3s;
  }
  .nav-logo{font-family:"Cormorant Garamond",serif;font-size:1.15rem;font-weight:300;letter-spacing:.1em;color:var(--deep);text-decoration:none;}
  .nav-logo em{font-style:italic;color:var(--rose);}
  .nav-links{display:flex;gap:2.2rem;list-style:none;}
  .nav-links a{font-size:.78rem;letter-spacing:.08em;font-weight:400;color:var(--deep);text-decoration:none;opacity:.65;transition:opacity .25s,color .25s;}
  .nav-links a:hover{opacity:1;color:var(--rose);}
  .nav-cta{font-size:.74rem;letter-spacing:.08em;background:var(--deep);color:#fff;padding:.62rem 1.5rem;text-decoration:none;transition:background .25s;white-space:nowrap;}
  .nav-cta:hover{background:var(--rose);}

  /* HERO */
  .hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;}
  .hero-left{display:flex;flex-direction:column;justify-content:center;padding:9rem 4rem 6rem;background:var(--cream);position:relative;z-index:1;}
  .hero-left::before{content:"";position:absolute;left:-1px;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,rgba(196,151,122,.4),transparent);}
  .hero-eyebrow{font-size:.72rem;letter-spacing:.18em;color:var(--rose);margin-bottom:1.6rem;display:flex;align-items:center;gap:.8rem;}
  .hero-eyebrow::after{content:"";width:32px;height:1px;background:var(--rose);}
  h1{font-family:"Cormorant Garamond",serif;font-size:clamp(3.2rem,5vw,5.2rem);font-weight:300;line-height:1.1;color:var(--deep);margin-bottom:1.8rem;}
  h1 em{font-style:italic;color:var(--rose);}
  .hero-sub{font-size:.92rem;line-height:2;color:var(--mid);font-weight:300;max-width:420px;margin-bottom:3rem;}
  .hero-actions{display:flex;gap:1rem;flex-wrap:wrap;}
  .btn-dark{display:inline-flex;align-items:center;gap:.7rem;background:var(--deep);color:#fff;padding:1rem 2.2rem;text-decoration:none;font-size:.78rem;letter-spacing:.06em;transition:background .25s,transform .25s;}
  .btn-dark:hover{background:var(--rose);transform:translateY(-2px);}
  .btn-outline{display:inline-flex;align-items:center;gap:.7rem;border:1px solid rgba(28,20,16,.25);color:var(--deep);padding:1rem 2.2rem;text-decoration:none;font-size:.78rem;letter-spacing:.06em;transition:border-color .25s,color .25s,transform .25s;}
  .btn-outline:hover{border-color:var(--rose);color:var(--rose);transform:translateY(-2px);}
  .hero-stats{display:flex;gap:3rem;margin-top:3.5rem;padding-top:2.5rem;border-top:1px solid rgba(196,151,122,.2);}
  .stat strong{font-family:"Cormorant Garamond",serif;font-size:2.4rem;font-weight:300;color:var(--deep);}
  .stat span{font-size:.7rem;letter-spacing:.06em;color:var(--mid);display:block;margin-top:.1rem;}
  .hero-right{position:relative;overflow:hidden;order:-1;min-height:100vh;}
  .hero-right img,.hero-right video{width:100%;height:100%;object-fit:cover;display:block;}
  .hero-overlay{position:absolute;inset:0;background:linear-gradient(to left,rgba(250,250,248,.12) 0%,transparent 40%);pointer-events:none;}
  .hero-tag{position:absolute;bottom:2.5rem;right:2.5rem;background:rgba(28,20,16,.82);backdrop-filter:blur(10px);padding:1rem 1.5rem;color:#fff;}
  .hero-tag .tag-label{font-size:.62rem;letter-spacing:.12em;color:var(--rose);margin-bottom:.3rem;}
  .hero-tag .tag-text{font-family:"Cormorant Garamond",serif;font-size:1.1rem;font-weight:300;font-style:italic;}

  /* SECTION COMMONS */
  .section-header{text-align:center;margin-bottom:4rem;}
  .s-eye{font-size:.68rem;letter-spacing:.2em;color:var(--rose);margin-bottom:.9rem;}
  .s-title{font-family:"Cormorant Garamond",serif;font-size:clamp(2.2rem,3.5vw,3.4rem);font-weight:300;color:var(--deep);line-height:1.15;}
  .s-title em{font-style:italic;color:var(--rose);}
  .s-sub{font-size:.9rem;color:var(--mid);font-weight:300;line-height:1.85;max-width:520px;margin:1.2rem auto 0;}

  /* PORTFOLIO CAROUSEL */
  .portfolio{padding:7rem 0;background:var(--deep);}
  .portfolio .section-header{padding:0 3rem;}
  .portfolio .s-title{color:#fff;}
  .portfolio .s-sub{color:rgba(255,255,255,.6);}
  .carousel-wrap{position:relative;margin-top:3.5rem;}
  .carousel{
    display:flex;gap:1rem;overflow-x:auto;scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch;padding:0 3rem 1rem;direction:ltr;
    scrollbar-width:none;
  }
  .carousel::-webkit-scrollbar{display:none;}
  .car-item{
    flex:0 0 auto;width:min(62vw,230px);position:relative;overflow:hidden;background:#000;
    padding-top:125%; scroll-snap-align:center;
  }
  .car-item img,.car-item video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;}
  .car-label{
    position:absolute;bottom:0;left:0;right:0;padding:1.3rem 1rem 1rem;
    background:linear-gradient(to top,rgba(28,20,16,.88) 10%,transparent);
    color:#fff;font-size:.7rem;letter-spacing:.1em;text-align:center;direction:rtl;
  }
  .car-nav{
    position:absolute;top:50%;transform:translateY(-50%);
    width:44px;height:44px;border-radius:50%;
    background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.28);
    color:#fff;display:flex;align-items:center;justify-content:center;
    cursor:pointer;font-size:1.3rem;backdrop-filter:blur(6px);
    transition:background .25s;z-index:5;
  }
  .car-nav:hover{background:rgba(196,151,122,.55);}
  .car-nav.prev{left:.5rem;}
  .car-nav.next{right:.5rem;}
  .carousel-hint{
    text-align:center;margin-top:1.4rem;font-size:.68rem;letter-spacing:.12em;
    color:rgba(255,255,255,.4);font-weight:300;
  }
  @media(max-width:760px){
    .car-nav{display:none;}
  }

  /* SERVICES */
  .services{padding:7rem 3rem;background:var(--warm);}
  .services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-top:4rem;}
  .svc.feature{grid-column:span 2;}
  .svc{background:var(--cream);padding:2.8rem 2.2rem;position:relative;transition:background .35s,transform .3s;}
  .svc:hover{background:var(--nude);transform:translateY(-3px);}
  .svc.dark{background:var(--deep);color:#fff;}
  .svc.dark:hover{background:#2e1f17;}
  .svc.dark .svc-title{color:#fff;}
  .svc.dark .svc-desc{color:rgba(255,255,255,.65);}
  .svc.dark .svc-num{color:rgba(196,151,122,.3);}
  .svc.dark .svc-icon{color:var(--rose);}
  .svc.accent{background:var(--rose);}
  .svc.accent:hover{background:#b8885e;}
  .svc.accent .svc-title,.svc.accent .svc-desc{color:#fff;}
  .svc.accent .svc-desc{color:rgba(255,255,255,.82);}
  .svc.accent .svc-num{color:rgba(255,255,255,.18);}
  .svc.accent .svc-tag{color:#fff;border-color:#fff;}
  .svc.accent .svc-icon{color:#fff;}
  .svc-num{font-family:"Cormorant Garamond",serif;font-size:4rem;font-weight:300;color:rgba(196,151,122,.15);line-height:1;margin-bottom:1.2rem;}
  .svc-icon{font-size:1.4rem;margin-bottom:.8rem;display:block;color:var(--rose);}
  .svc-title{font-family:"Cormorant Garamond",serif;font-size:1.45rem;font-weight:400;color:var(--deep);margin-bottom:.6rem;}
  .svc-desc{font-size:.84rem;line-height:1.85;color:var(--mid);font-weight:300;}
  .svc-tag{display:inline-block;margin-top:1.2rem;font-size:.64rem;letter-spacing:.1em;color:var(--rose);border-bottom:1px solid var(--rose);padding-bottom:2px;}


  /* ABOUT */
  .about-strip{display:grid;grid-template-columns:1fr 1fr;min-height:600px;overflow:hidden;}
  .about-img{overflow:hidden;}
  .about-img img{width:100%;height:100%;object-fit:cover;object-position:center 15%;display:block;}
  .about-text{background:var(--deep);padding:6rem 5rem;display:flex;flex-direction:column;justify-content:center;}
  .about-text .s-eye{color:var(--rose);text-align:right;}
  .about-text .s-title{color:#fff;text-align:right;}
  .about-text .s-title em{color:var(--rose);}
  .about-text p{font-size:.9rem;line-height:2;color:rgba(255,255,255,.7);font-weight:300;margin-top:1.8rem;max-width:440px;}
  .about-text .btn-rose{display:inline-flex;align-items:center;gap:.7rem;background:var(--rose);color:#fff;padding:1rem 2.2rem;text-decoration:none;font-size:.78rem;letter-spacing:.06em;margin-top:2.5rem;transition:background .25s,transform .25s;}
  .about-text .btn-rose:hover{background:var(--gold);transform:translateY(-2px);}

  /* CONTACT */
  .contact{padding:7rem 3rem;background:var(--warm);}
  .contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start;max-width:1100px;margin:0 auto;}
  .contact-info h2{font-family:"Cormorant Garamond",serif;font-size:clamp(2.4rem,3.5vw,3.8rem);font-weight:300;color:var(--deep);line-height:1.1;margin-bottom:1.8rem;}
  .contact-info h2 em{color:var(--rose);font-style:italic;}
  .contact-info p{font-size:.9rem;line-height:2;color:var(--mid);font-weight:300;margin-bottom:2.5rem;}
  .contact-details{display:flex;flex-direction:column;gap:1.4rem;}
  .cd-item{display:flex;align-items:flex-start;gap:1rem;}
  .cd-icon{width:40px;height:40px;background:var(--deep);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#fff;font-size:.9rem;}
  .cd-label{font-size:.64rem;letter-spacing:.1em;color:var(--rose);margin-bottom:.2rem;}
  .cd-value{font-size:.92rem;color:var(--deep);font-weight:400;}
  .cd-value a{color:var(--deep);text-decoration:none;}
  .cd-value a:hover{color:var(--rose);}
  .contact-action{background:var(--deep);padding:3.5rem;display:flex;flex-direction:column;gap:1.5rem;}
  .ca-title{font-family:"Cormorant Garamond",serif;font-size:2rem;font-weight:300;color:#fff;font-style:italic;line-height:1.3;}
  .ca-sub{font-size:.85rem;color:rgba(255,255,255,.6);font-weight:300;line-height:1.85;}
  .ca-buttons{display:flex;flex-direction:column;gap:.8rem;margin-top:.5rem;}
  .btn-wa{display:flex;align-items:center;justify-content:center;gap:.8rem;background:#25D366;color:#fff;padding:1rem 1.5rem;text-decoration:none;font-size:.8rem;letter-spacing:.06em;font-weight:500;transition:filter .25s,transform .25s;}
  .btn-wa:hover{filter:brightness(1.1);transform:translateY(-2px);}
  .btn-ig{display:flex;align-items:center;justify-content:center;gap:.8rem;background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);color:#fff;padding:1rem 1.5rem;text-decoration:none;font-size:.8rem;letter-spacing:.06em;font-weight:500;transition:filter .25s,transform .25s;}
  .btn-ig:hover{filter:brightness(1.1);transform:translateY(-2px);}

  /* FOOTER */
  footer{background:var(--deep);color:#fff;padding:4rem 3rem 2rem;display:grid;grid-template-columns:2fr 1fr 1fr;gap:4rem;}
  .ft-logo{font-family:"Cormorant Garamond",serif;font-size:1.4rem;font-weight:300;letter-spacing:.1em;color:#fff;margin-bottom:1.2rem;}
  .ft-logo em{font-style:italic;color:var(--rose);}
  .ft-tag{font-size:.82rem;line-height:1.9;color:rgba(255,255,255,.5);font-weight:300;max-width:260px;}
  .ft-col-title{font-size:.66rem;letter-spacing:.15em;color:var(--rose);margin-bottom:1.2rem;}
  .ft-links{list-style:none;display:flex;flex-direction:column;gap:.6rem;}
  .ft-links a{font-size:.84rem;color:rgba(255,255,255,.55);text-decoration:none;font-weight:300;transition:color .25s;}
  .ft-links a:hover{color:var(--rose);}
  .ft-bottom{grid-column:1/-1;margin-top:2.5rem;padding-top:1.4rem;border-top:1px solid rgba(255,255,255,.08);display:flex;justify-content:space-between;align-items:center;}
  .ft-copy{font-size:.72rem;color:rgba(255,255,255,.28);font-weight:300;}
  .ft-ig{display:flex;align-items:center;gap:.5rem;font-size:.72rem;color:rgba(255,255,255,.4);text-decoration:none;font-weight:300;transition:color .25s;}
  .ft-ig:hover{color:var(--rose);}

  /* ANIM */
  .fade{opacity:0;transform:translateY(26px);transition:opacity .7s ease,transform .7s ease;}
  .fade.on{opacity:1;transform:none;}
  .d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.3s;}.d4{transition-delay:.4s;}

  /* RESPONSIVE */
  @media(max-width:960px){
    nav{padding:1rem 1.5rem;}
    .nav-links{display:none;}
    .hero{grid-template-columns:1fr;}
    .hero-right{height:55vw;min-height:280px;order:-1;}
    .hero-left{padding:3rem 1.5rem 4rem;}
    .services-grid{grid-template-columns:1fr 1fr;}
    .svc.feature{grid-column:span 2;}
    .about-strip{grid-template-columns:1fr;}
    .about-img{height:55vw;}
    .about-text{padding:4rem 2rem;}
    .contact-wrap{grid-template-columns:1fr;gap:3rem;}
    footer{grid-template-columns:1fr;gap:2rem;padding:3rem 1.5rem 2rem;}
    .ft-bottom{flex-direction:column;gap:.8rem;text-align:center;}
  }
  @media(max-width:600px){
    .services-grid{grid-template-columns:1fr;}
    .hero-stats{gap:1.8rem;}
    .contact{padding:5rem 1.5rem;}
    .services{padding:5rem 1.5rem;}
  }
</style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">Dana <em>Bejerano</em></a>
  <ul class="nav-links">
    <li><a href="#gallery">פורטפוליו</a></li>
